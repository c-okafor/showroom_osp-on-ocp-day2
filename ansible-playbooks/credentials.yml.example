# Example credentials file for RHOSO deployment
# Copy this file to credentials.yml and update with your actual values
# Usage: ./deploy-from-bastion.sh --credentials credentials.yml full
#
# Registry credentials are always required.
# Subscription credentials use ONE mode only — Customer Portal OR Satellite, not both.

# Red Hat Registry Service Account Credentials (required)
# Get these from: https://access.redhat.com/articles/RegistryAuthentication#creating-registry-service-accounts-6
registry_username: "12345678|myserviceaccount"
registry_password: "eyJhbGciOiJSUzUxMiJ9..."

# --- Option A: Customer Portal subscription ---
rhc_username: "your-rh-username@email.com"
rhc_password: "YourRHPassword123"

# --- Option B: Satellite subscription — RHDP labs / demosat ---
# Comment out Option A and uncomment Option B instead (do not use both).
# satellite_url: "your_satellite.example.com"
# satellite_org: "your_satellite_org"
# ocp4_workload_rhoso_deployment_rhc_activation_key: "your-activation-key"
# satellite_insecure: false  # set true only if Katello CA install fails
